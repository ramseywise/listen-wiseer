# ── Spotify OAuth ────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_USER_ID=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Tavily (artist/genre web context) ────────────────────────────────────────
TAVILY_API_KEY=

# ── Postgres checkpointer ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Persistent cross-session memory store (optional; omit for in-memory dev mode) ──
# MEMORY_STORE_URL=postgresql://user:pass@localhost:5432/listen_wiseer

# ── Optional ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_TRACING=false

# ── Dev/test ─────────────────────────────────────────────────────────────────
# deepeval pings telemetry on import; blocks for minutes in restricted-network
# environments instead of failing fast. `make test*` targets export this already —
# only needed if you run `pytest` directly, outside make.
DEEPEVAL_TELEMETRY_OPT_OUT=YES

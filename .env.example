# ── Spotify ──────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback
SPOTIFY_USER_ID=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Web search (artist/genre context) ────────────────────────────────────────
TAVILY_API_KEY=

# ── Last.fm (audio feature proxy — activate key at last.fm/api before use) ───
LAST_FM_API_KEY=
LAST_FM_ID=

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_TRACING=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# ── LangFuse (optional — set ENABLE_LANGFUSE=true to activate) ───────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
ENABLE_LANGFUSE=false

# ── MCP server ────────────────────────────────────────────────────────────────
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8765

# ── Agent ─────────────────────────────────────────────────────────────────────
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60

# ── Persistence ───────────────────────────────────────────────────────────────
# Local dev: leave blank → MemorySaver (sessions lost on restart)
# Docker: set automatically via docker-compose (postgres service)
# Manual/prod: set to your postgres connection string
POSTGRES_URL=
POSTGRES_PASSWORD=changeme
# REDIS_URL=redis://localhost:6379
